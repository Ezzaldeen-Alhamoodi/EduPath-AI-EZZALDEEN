# EduPath AI EZZALDEEN environment variables

SECRET_KEY=change-this-secret-key
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Local default
DATABASE_URL=sqlite:///edupath_ai_ezzaldeen.db

# Render PostgreSQL example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Email SMTP for verification and password reset
MAIL_SERVER=smtp-mail.outlook.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=edupath.ai.ezzaldeen.app@outlook.com
MAIL_PASSWORD=your_outlook_app_password_here
MAIL_DEFAULT_SENDER=edupath.ai.ezzaldeen.app@outlook.com

# Public security: keep true in production
REQUIRE_EMAIL_VERIFICATION=false

# Comma-separated admin emails
ADMIN_EMAILS=geni49607@gmail.com

# Default AI Coach uses per day for normal users
DEFAULT_AI_DAILY_LIMIT=1

# Keep users logged in for this many days
REMEMBER_LOGIN_DAYS=365

CRON_SECRET=change-this-long-random-secret
APP_TIMEZONE_OFFSET_HOURS=3
EMAIL_REMINDER_WINDOW_MINUTES=15
MAIL_ENABLED=false
MAIL_TIMEOUT=8
SEND_AUTH_EMAILS=false
SEND_WELCOME_EMAIL=false
SEND_ADMIN_EMAILS=false